# Frontend environment variables — keys only, NO values.
# Copy to `.env.local` and fill in. Secrets are set per platform (Vercel) per D-035; never commit values.
# NEXT_PUBLIC_* values are exposed to the browser by design.

# Base URL of the FastAPI backend (the Railway URL in production).
NEXT_PUBLIC_API_BASE_URL=

# Supabase project URL (public; client auth in later phases).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key (client auth in later phases).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
