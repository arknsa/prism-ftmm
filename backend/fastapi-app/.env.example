# Backend environment variables — keys only, NO values.
# Copy to `.env` and fill in. Secrets are set per platform (Railway) per D-035; never commit values.

# Runtime: "local" or "production"
APP_ENV=

# Log verbosity: "DEBUG", "INFO", "WARNING", "ERROR". Defaults to INFO.
# In production, set "WARNING" to reduce noise; set "DEBUG" only temporarily.
LOG_LEVEL=

# Comma-separated list of allowed CORS origins (e.g. the Vercel frontend URL).
BACKEND_CORS_ORIGINS=

# Supabase Postgres connection — use the POOLER URI.
DATABASE_URL=

# Supabase project + server keys (consumed from Phase 2 onward; set now so env is complete).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
